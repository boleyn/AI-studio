# =========================
# Required
# =========================
MONGODB_URI=mongodb://127.0.0.1:27017/nextjs_ai_studio
JWT_SECRET=replace_with_a_long_random_secret
AUTH_COOKIE_SECURE=

# LLM auth (AIProxy first)
AIPROXY_API_ENDPOINT=
AIPROXY_API_TOKEN=

# Optional fallback: direct OpenAI-compatible endpoint
OPENAI_BASE_URL=
CHAT_API_KEY=

# Optional model catalog (single source)
CHAT_MODEL_CONFIG_FILE=config/config.json

# Optional MCP
MCP_SERVER_URLS=
# Example (AIChat style):
# MCP_SERVER_URLS=[{"name":"mcp-gitlab-kb","url":"http://10.21.8.6:8008/sse"}]
# With headers:
# MCP_SERVER_URLS=[{"name":"mcp-private","url":"https://example.com/sse","headers":{"Authorization":"Bearer xxx"}}]
# MCP_SERVERS=

# ClawHub one-click edit key validation
AI_STUDIO_KEY=d0a88f10bc8e4069020c78c74a1176a7f9f3bb5c90f3f02880cf564234f6e299



# File parse config is read from config/config.json -> customPdfParse

# =========================
# Object Storage (S3/MinIO)
# =========================
STORAGE_VENDOR=minio
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_PUBLIC_BUCKET=
STORAGE_PRIVATE_BUCKET=
STORAGE_EXTERNAL_ENDPOINT=
STORAGE_S3_ENDPOINT=
STORAGE_S3_FORCE_PATH_STYLE=true
STORAGE_S3_MAX_RETRIES=3
# Chat attachment GET presigned URL TTL (seconds), default 2592000 = 30 days
CHAT_FILE_GET_URL_EXPIRES_IN_SECONDS=2592000

# =========================
# Optional Feishu OAuth
# =========================
FEISHU_APP_ID=
FEISHU_REDIRECT_URI=http://localhost:3000/auth/feishu/callback
FEISHU_APP_SECRET=
FEISHU_DEFAULT_PASSWORD=Feishu@123456

# =========================
# Optional ClawHub publish bridge
# =========================
SKILL_HUB=
# Shared secret with ClawHub(SKILL_PUBLISH_PROXY_SECRET), used to bind publish owner by Feishu open_id.
SKILL_HUB_PROXY_SECRET=ch_81547e7a828f846d80511c4d5ac4a4eefd3f99b1597b293d
